<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Authors>wmizera</Authors>
    <Company>wmizera Inc.</Company>
    <Product>DistributedAPI</Product>
    <Description>Test tools for DistributedAPI project</Description>
    <IsPackable>true</IsPackable>
    <PackageOutputPath>$(SolutionDir)local-nuget</PackageOutputPath>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <PropertyGroup>
    <BaseVersion>1.0.0</BaseVersion>
    <PackageReleaseNotes>Release notes</PackageReleaseNotes>
  </PropertyGroup>

  <PropertyGroup Condition="'$(ContinuousIntegrationBuild)' != 'true'">
    <!-- Local build -->
    <Version>$(BaseVersion)-local-$([System.DateTime]::UtcNow.ToString("yyyyMMddHHmm"))</Version>
  </PropertyGroup>

  <PropertyGroup Condition="'$(ContinuousIntegrationBuild)' == 'true'">
    <!-- Pipeline build -->
    <Version>$(BaseVersion)-ci-$(BuildNumber)</Version>
  </PropertyGroup>
  
  <ItemGroup>
    <PackageReference Include="DistributedAPI.CommonTools" Version="1.0.0-local-202603062248" />
  </ItemGroup>

</Project>
