{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeyVault": {
    "Url": "https://wmizera-example-kv.vault.azure.net/"
  },
  "CorsPolicy" : {
    "AllowedOrigins": [
      "https://localhost:3000"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Host",
      "User-Agent",
      "Accept",
      "Accept-Encoding",
      "Connection",
      "Content-Type",
      "Content-Length",
      "Authorization"
    ]
  }
}
